# Recommended setup for your current stage
# Environment variables

# ── Frontend (Vite) ──────────────────────────────────────
# URL of your backend API server (Express + Prisma).
# In development, leave VITE_API_URL *unset* (delete or comment out the line
# below) to use relative URLs so the Vite proxy can rewrite /api → http://localhost:5000.
# If VITE_API_URL is set (even to an empty string), the app will use that as the
# base URL instead of relying on the proxy. In production set this to your deployed
# API origin, e.g.: https://api.shipforge.dev
VITE_API_URL=

# ── Backend API ──────────────────────────────────────────
# ShipForge API Configuration
SHIPFORGE_API_URL=https://shipforge.dev

# Node Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info

# Copilot Configuration
COPILOT_AGENT_MODE=enhanced
