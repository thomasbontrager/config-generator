# ShipForge Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# All variables listed here are validated at startup by lib/env.ts.

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=https://shipforge.dev
NEXT_PUBLIC_APP_URL=https://shipforge.dev

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shipforge

# Optional — Redis connection string for queues / cache
# REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be at least 32 characters. NextAuth v4 also reads this as NEXTAUTH_SECRET.
AUTH_SECRET=your-random-32-char-secret-here

# Optional — set to ".shipforge.dev" to share cookies across subdomains
# COOKIE_DOMAIN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# All five variables are required; the app will refuse to start without them.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PORTAL_RETURN_URL=https://shipforge.dev/billing

# ─── GitHub OAuth + App ───────────────────────────────────────────────────────
# OAuth app credentials (https://github.com/settings/developers):
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App credentials (for repo operations):
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=<PEM-encoded private key, newlines as \n>
# GITHUB_WEBHOOK_SECRET=

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_DEFAULT=gpt-4o-mini
# AI_PROVIDER_DEFAULT=none   # openai | anthropic | none

# ─── Email ────────────────────────────────────────────────────────────────────
# At least ONE of the following providers must be configured for:
#   - Password reset emails (/api/auth/forgot-password)
#   - Contact form submissions (/api/contact)
#
# Provider 1 — Resend (recommended, https://resend.com):
# RESEND_API_KEY=re_...
#
# Provider 2 — Mailgun:
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.shipforge.dev
#
# Inbound contact address (where contact form messages are delivered):
CONTACT_EMAIL=hello@shipforge.dev

# ─── Storage (S3-compatible) ──────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # set for Cloudflare R2 or other S3-compatible providers

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=
# PLAUSIBLE_DOMAIN=shipforge.dev
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" or "1" to enable; omit or set to anything else to disable.
# FEATURE_ENABLE_DOCS=false
# FEATURE_ENABLE_TEAM_WORKSPACES=false
# FEATURE_ENABLE_ADMIN=false
