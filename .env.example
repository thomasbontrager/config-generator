# Recommended setup for your current stage
# Environment variables

# ShipForge API Configuration
SHIPFORGE_API_URL=https://shipforge.dev

# Frontend API URL (backend base URL for the React app)
# In development this defaults to http://localhost:5000 (see src/config/api.js)
# Set this to your deployed backend URL for production builds
VITE_API_URL=https://api.shipforge.dev

# Node Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info

# Copilot Configuration
COPILOT_AGENT_MODE=enhanced
