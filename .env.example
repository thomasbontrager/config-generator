# ShipForge Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=https://shipforge.dev
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shipforge

# ─── Authentication Providers ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ────────────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Storage ─────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=

# ─── Legacy / Unused ─────────────────────────────────────────────────────────
# VITE_API_URL=https://api.shipforge.dev  (no longer used - kept for reference)
