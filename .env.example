# ShipForge Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=https://shipforge.dev
NEXTAUTH_SECRET=your-random-32-char-secret-here   # generate with: openssl rand -base64 32

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shipforge

# ─── Authentication Providers ────────────────────────────────────────────────
# Google: https://console.developers.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Required — app will refuse to start without STRIPE_SECRET_KEY.
STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe Dashboard → Webhooks
STRIPE_PRICE_ID_PRO=price_...          # created in Stripe Dashboard → Products
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # or pk_test_...

# ─── Email ────────────────────────────────────────────────────────────────────
# At least ONE of the following providers must be configured for:
#   - Password reset emails (/api/auth/forgot-password)
#   - Contact form submissions (/api/contact)
#
# Provider 1 — Resend (recommended, https://resend.com):
RESEND_API_KEY=re_...
EMAIL_FROM=ShipForge <noreply@shipforge.dev>
#
# Provider 2 — Generic SMTP (Mailgun SMTP, SES SMTP, self-hosted Postfix, etc.):
# EMAIL_SERVER_HOST=smtp.mailgun.org
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=postmaster@mg.shipforge.dev
# EMAIL_SERVER_PASSWORD=...
# EMAIL_FROM=ShipForge <noreply@shipforge.dev>
#
# Inbound contact address (where contact form messages are delivered):
CONTACT_EMAIL=hello@shipforge.dev

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=
