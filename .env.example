# Recommended setup for your current stage
# Environment variables

# Legacy / unused configuration
# NOTE: SHIPFORGE_API_URL is not used by the current frontend-only app.
# It previously pointed to the main site domain and is kept here only for reference.
# If you don't explicitly need it for external tooling, you can ignore or remove it.
# SHIPFORGE_API_URL=https://shipforge.dev

# Frontend API URL (backend base URL for the React app)
# In development this defaults to http://localhost:5000 (see src/config/api.js)
# Set this to your deployed backend URL for production builds
# IMPORTANT: Do not include a trailing slash (use https://api.shipforge.dev, not https://api.shipforge.dev/)
VITE_API_URL=https://api.shipforge.dev

# Node Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info

# Copilot Configuration
COPILOT_AGENT_MODE=enhanced
