# Recommended setup for your current stage
# Environment variables

# ── Frontend (Vite) ──────────────────────────────────────
# URL of your backend API server (Express + Prisma).
# In development the Vite proxy rewrites /api → http://localhost:5000,
# so you can leave this blank locally.
# In production set this to your deployed API origin, e.g.:
#   https://api.shipforge.dev
VITE_API_URL=

# ── Backend API ──────────────────────────────────────────
# ShipForge API Configuration
SHIPFORGE_API_URL=https://shipforge.dev

# Node Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info

# Copilot Configuration
COPILOT_AGENT_MODE=enhanced
