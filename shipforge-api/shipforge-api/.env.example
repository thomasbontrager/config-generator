# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/shipforge"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-secure-random-string-at-least-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional — localhost:5173 is always allowed)
CORS_ORIGIN=http://localhost:5173,https://shipforge.dev

# ── PayPal ────────────────────────────────────────────────────────────────────
# Get credentials from https://developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Use sandbox for testing: https://api-m.sandbox.paypal.com
# Use live for production: https://api-m.paypal.com
PAYPAL_API=https://api-m.sandbox.paypal.com
# Create a subscription plan in the PayPal dashboard and paste its ID here
PAYPAL_PLAN_ID=

# ── Stripe (optional — use PayPal OR Stripe) ─────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from your Stripe product/price dashboard
STRIPE_PRICE_ID=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
