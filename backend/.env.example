# Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL="file:./dev.db"

# JWT Secret (must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# CORS allowed origins (comma-separated)
# Production: CORS_ORIGIN=https://shipforge.dev,https://www.shipforge.dev
CORS_ORIGIN=http://localhost:5173,https://shipforge.dev,https://www.shipforge.dev

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from https://dashboard.stripe.com/webhooks — endpoint: https://api.shipforge.dev/api/billing/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from https://dashboard.stripe.com/prices
STRIPE_PRICE_ID=price_YOUR_PRICE_ID_HERE
