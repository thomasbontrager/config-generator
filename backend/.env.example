# Backend Environment Variables
# Copy this to .env and fill in your values

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/shipforge"

# JWT Secret (must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,https://shipforge.dev

# Admin credentials (used by scripts/create-admin.js)
ADMIN_EMAIL=admin@shipforge.dev
ADMIN_PASS=StrongPass123

# PayPal (required for billing)
# API base URL: use https://api-m.sandbox.paypal.com for sandbox, https://api-m.paypal.com for production
PAYPAL_API=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# Subscription plan ID from PayPal Dashboard → Products & Plans
PAYPAL_PLAN_ID=your-paypal-plan-id
# Webhook ID from PayPal Dashboard → Webhooks (used for signature verification)
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# PayPal redirect URLs (update with your deployed frontend URL)
BRAND_NAME=Shipforge
RETURN_URL=http://localhost:5173/billing/success
CANCEL_URL=http://localhost:5173/billing/cancel

